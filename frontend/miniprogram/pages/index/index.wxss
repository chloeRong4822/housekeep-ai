.search-bar {
  padding: 20rpx 0;
}
.search-input {
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
}
.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

.banner {
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.banner-item {
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 40rpx;
  color: #fff;
}
.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.banner-sub {
  font-size: 24rpx;
  opacity: 0.9;
}

.quick-post {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.quick-post-left {
  display: flex;
  flex-direction: column;
}
.quick-post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}
.quick-post-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}
.quick-post-btn {
  background: #fff;
  color: #667eea;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.category-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.category-name {
  font-size: 26rpx;
  color: #333;
}

.hot-tags {
  margin-bottom: 20rpx;
}
.hot-tags-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: block;
}
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.company-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.company-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
}
.company-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.company-img-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
}
.company-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.company-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.company-name {
  font-size: 30rpx;
  font-weight: bold;
}
.company-rating {
  font-size: 26rpx;
  color: #e6a23c;
}
.company-tags {
  margin-bottom: 8rpx;
}
.company-intro {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.4;
}
.company-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
}
