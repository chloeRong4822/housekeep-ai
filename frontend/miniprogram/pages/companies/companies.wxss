.filter-bar {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}
.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
}
.filter-arrow {
  font-size: 20rpx;
  color: #999;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}
.tab-item.active {
  color: #667eea;
  border-bottom-color: #667eea;
  font-weight: bold;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.company-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
}
.company-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.company-img-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}
.company-info { flex: 1; }
.company-name-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.company-name { font-size: 30rpx; font-weight: bold; }
.company-rating { font-size: 26rpx; color: #e6a23c; }
.company-tags { margin-bottom: 8rpx; }
.company-intro { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.company-meta { display: flex; justify-content: space-between; font-size: 22rpx; }

.nanny-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
}
.nanny-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.nanny-avatar-text { font-size: 48rpx; font-weight: bold; color: #fff; }
.nanny-info { flex: 1; }
.nanny-name-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.nanny-name { font-size: 30rpx; font-weight: bold; }
.nanny-rating { font-size: 26rpx; color: #e6a23c; }
.nanny-meta { font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.nanny-tags { margin-bottom: 8rpx; }
.nanny-salary { font-size: 26rpx; color: #f56c6c; font-weight: bold; margin-bottom: 12rpx; }
.nanny-actions { display: flex; justify-content: flex-end; }
.contact-btn { padding: 8rpx 24rpx; font-size: 24rpx; }
