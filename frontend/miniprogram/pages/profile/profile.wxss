.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-bottom: 16rpx;
}
.user-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}
.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}
.user-phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.stats-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}
.stat-item { text-align: center; }
.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}
.stat-label { font-size: 24rpx; color: #999; }

.section { margin-bottom: 20rpx; }
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.post-list { display: flex; flex-direction: column; gap: 16rpx; }
.post-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}
.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.post-type { font-size: 30rpx; font-weight: bold; }
.post-status { font-size: 24rpx; color: #67c23a; }
.post-desc { font-size: 26rpx; color: #666; margin-bottom: 12rpx; }
.post-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999;
}
.post-score { color: #667eea; }

.fav-list { display: flex; flex-direction: column; gap: 16rpx; }
.fav-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}
.fav-name { font-size: 30rpx; font-weight: bold; margin-bottom: 8rpx; }
.fav-tags { margin-bottom: 12rpx; }
.fav-action {
  font-size: 26rpx;
  color: #667eea;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-item:last-child { border-bottom: none; }
.menu-arrow { color: #999; font-size: 26rpx; }
