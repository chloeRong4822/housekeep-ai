.progress-bar {
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  margin-bottom: 40rpx;
  position: relative;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx;
  transition: width 0.3s;
}
.progress-text {
  position: absolute;
  right: 0;
  top: -40rpx;
  font-size: 24rpx;
  color: #667eea;
}

.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  min-height: 600rpx;
}
.question-text {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.option-item {
  padding: 28rpx 32rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  font-size: 30rpx;
  text-align: center;
  transition: all 0.2s;
}
.option-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

.input-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.question-input {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
}
.input-unit {
  font-size: 26rpx;
  color: #999;
  text-align: right;
}
.next-btn {
  margin-top: 20rpx;
}

.switch-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.radio-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.radio-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.back-btn {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #667eea;
}
